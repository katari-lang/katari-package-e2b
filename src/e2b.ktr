// A self-contained tool: run Python in an e2b sandbox. The sandbox is OWNED BY THE PROVIDER and shared by
// every `run_python` call in its scope — a stateful kernel, so variables, imports, and files persist across
// the model's steps (not a fresh process per call, which would make the model's `soup` disappear mid-turn).
//
// The split is deliberate. The PROVIDER serves only the ENVIRONMENT — the `session` request hands back a
// sandbox id plus the api key — and `run_python` runs the code IN ITS OWN (terminal) context. So an
// execution failure surfaces at the call site, where an AI tool loop that dispatched `run_python` catches it
// and feeds it back to the model, instead of welling up through the provider's handler to the run's root.
//
// Neither sidecar function throws: each returns a result value (`{ ok, ... }`) that the Katari side reads
// and turns into a typed `execution_error` at the right place. A throw from the sidecar would cross back as
// a panic and tear the whole run down, out of reach of the loop — the very failure this split avoids.

@"The e2b sandbox could not run your code: the sidecar reported a connection-level failure (a bad key, an
expired sandbox that will not reconnect, e2b unreachable). `run_python` raises it for a run failure, and the
provider for an open failure. A Python error in your code is NOT this — it comes back as ordinary output."
data execution_error(message: string)

@"The ambient e2b environment the provider serves: the @session_id@ of the sandbox shared across the scope,
and the @api_key@ the sidecar authenticates with (a `string of private`, protected by its taint).
`run_python` performs `session` to obtain this, then runs its code against it in its own context."
data session_data(session_id: string, api_key: string of private)

@"Open a fresh e2b sandbox and return the sidecar's result: `{ ok: true, session }` — the id every later
`e2b_run_in` replays to reach the same sandbox — or `{ ok: false, message }` when the sandbox could not be
opened. The api key never leaves the provider; it is passed straight to the sidecar."
external agent e2b_open(api_key: string of private) -> unknown

@"Run Python in the sandbox named by @session@ and return the sidecar's result: `{ ok: true, output }` with
its stdout / value / error text, or `{ ok: false, message }` on a sidecar-level failure. The sidecar
reconnects to that sandbox — recreating it under the same handle if it has expired — so state from earlier
calls in the same session is still there (only an actually-expired sandbox loses it)."
external agent e2b_run_in(session: string, code: string, api_key: string of private) -> unknown

@"The ambient e2b environment capability: the sandbox id + api key a tool runs against. The provider serves
it — opening the sandbox lazily on the first request and sharing it after — and `run_python` performs it to
get the environment before running code in its own context."
request session() -> session_data

@"Whether the sidecar reported success — the `ok` discriminant of a result value, false for a malformed or
failed result."
agent succeeded(result: unknown) -> boolean {
  match (json.field(target = result, key = "ok")) {
    case boolean(value) -> value
    case _ -> false
  }
}

@"Provide an e2b environment for the extent of the continuation: ONE sandbox, opened lazily on the first
`session` request and shared by every `run_python` after, so the model's steps build on each other's state.
The session lives as long as this provider scope — wrap a single turn in its own `use e2b.provider(...)` for
strict per-turn isolation. A sandbox that cannot be opened raises `execution_error` here, at the provider's
use site."
agent provider[R, effect E](
  api_key: string of private,
  continuation: agent (value: null) -> R with {...E, session},
) -> R with E | io | prelude.throw[execution_error] {
  use handler (var current: string = "") {
    request session() {
      // Open the sandbox on first use, then reuse its handle for every later request in this scope. A
      // failed open raises `execution_error` rather than resuming, so it surfaces at the provider's use site.
      let resolved = if (current == "") {
        let opened = e2b_open(api_key = api_key)
        if (succeeded(result = opened)) {
          session_data(session_id = json.text(target = json.field(target = opened, key = "session")), api_key = api_key)
        } else {
          prelude.throw(error = execution_error(message = json.text(target = json.field(target = opened, key = "message"))))
        }
      } else {
        session_data(session_id = current, api_key = api_key)
      }
      next resolved with { current = resolved.session_id }
    }
  }
  continuation(value = null)
}

@"Tool: execute Python code and return its output. Runs in a PERSISTENT sandbox shared across this
conversation — variables, imports, and files you defined in earlier calls are still available, so build on
them instead of repeating work. (If something you expected is missing, just define it again.) A run that
fails at the sandbox level raises `execution_error`; a Python error in your code comes back as ordinary
output text."
agent run_python(code: string) -> string with session | io | prelude.throw[execution_error] {
  let environment = session()
  let outcome = e2b_run_in(session = environment.session_id, code = code, api_key = environment.api_key)
  if (succeeded(result = outcome)) {
    json.text(target = json.field(target = outcome, key = "output"))
  } else {
    prelude.throw(error = execution_error(message = json.text(target = json.field(target = outcome, key = "message"))))
  }
}
